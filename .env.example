# ── Frontend (React) ─────────────────────────────────────────
# Copy to .env.local and fill in your values

# Cognito
REACT_APP_USER_POOL_ID=us-east-1_XXXXXXXXX
REACT_APP_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_AWS_REGION=us-east-1

# Backend API
REACT_APP_API_ENDPOINT=https://your-api-gateway-url.amazonaws.com/prod
# For local dev: REACT_APP_API_ENDPOINT=http://localhost:4000

# ── Backend (server/.env) ─────────────────────────────────────
# DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=melina
# DB_USER=melina_user
# DB_PASSWORD=your-secure-password
# DB_SSL=true

# COGNITO_USER_POOL=us-east-1_XXXXXXXXX
# AWS_REGION=us-east-1
# FRONTEND_URL=https://your-amplify-app.amplifyapp.com
# PORT=4000
