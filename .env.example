# ── Frontend (React) ─────────────────────────────────────────
# Copy to .env.local and fill in your values

REACT_APP_REGION=us-east-1

# Backend API
REACT_APP_API_ENDPOINT=https://your-api-gateway-url.amazonaws.com/prod
# For local dev: REACT_APP_API_ENDPOINT=http://localhost:4000

# Chat bridge (local Anthropic + MCP bridge)
REACT_APP_CHAT_API_ENDPOINT=http://localhost:4001
REACT_APP_CHAT_MCP_SERVER_ID=land_finance

# ── Backend / Lambda (serverless deploy env vars) ─────────────
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=melina
DB_USER=melina_user
DB_PASSWORD=your-secure-password
DB_SSL=true

JWT_SECRET=replace-with-a-long-random-secret
APP_REGION=us-east-1
FRONTEND_URL=https://your-amplify-app.amplifyapp.com
PORT=4000

# ── VPC (required for Lambda → RDS) ──────────────────────────
LAMBDA_SG_ID=sg-XXXXXXXXXXXXXXXXX
SUBNET_ID_1=subnet-XXXXXXXXXXXXXXXXX
SUBNET_ID_2=subnet-XXXXXXXXXXXXXXXXX

# ── RDS Instance ARN (for Lambda IAM policy) ───────────────────
RDS_INSTANCE_ARN=arn:aws:rds:us-west-2:ACCOUNT-ID:db:instance-name
